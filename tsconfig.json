{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": ["vite/client"],
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "paths": {
      "~/*": ["./app/*"],
      "@auth/core": ["./node_modules/@auth/core"],
      "@auth/core/*": ["./node_modules/@auth/core/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules", ".vinxi", "dist"]
}
